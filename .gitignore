# Root Gitignore

# Dependency folders
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment configurations (credentials)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
backend/.env.local

# Local uploads and media storage fallbacks
backend/uploads/*
!backend/uploads/.gitkeep

# System/IDE configs
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Build output directories
dist/
dist-ssr/
build/

# Debug and log files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Temporary test scripts
backend/test-*.js
backend/test-*.mjs
backend/test-*.txt
